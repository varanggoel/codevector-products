# Neon connection string (from the Neon dashboard -> Connection Details).
# Use the "pooled" connection string for the app server.
DATABASE_URL=postgresql://user:password@ep-xxxx-pooler.region.aws.neon.tech/dbname?sslmode=require

# Port the API server listens on (Render sets this automatically).
PORT=3000

# Set to "disable" only when pointing at a local Postgres without SSL.
PGSSL=require
